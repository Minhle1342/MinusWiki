# MinusWiki Configuration

# Choose your preferred LLM provider.
# If GEMINI_API_KEY is defined, it will prioritize Gemini (gemini-1.5-flash).
# If only OPENAI_API_KEY is defined, it will use OpenAI (gpt-4o-mini).
# If neither is set, the server will run in a mock simulation mode for testing.

LLM_PROVIDER=gemini

GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite-preview

OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=DeepSeek-V4-Flash
OPENAI_API_BASE=https://api.deepseek.com

# Server Port
PORT=3000
